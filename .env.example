#--------------------------------------------------------------------
# RAILWAY PRODUCTION ENVIRONMENT TEMPLATE
#--------------------------------------------------------------------
# Copy this file to .env and fill in your Railway MySQL credentials
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'https://your-railway-app.railway.app/'

#--------------------------------------------------------------------
# DATABASE (Get these from Railway MySQL addon)
#--------------------------------------------------------------------
database.default.hostname = your_railway_mysql_host
database.default.database = railway
database.default.username = root
database.default.password = your_railway_mysql_password
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generate a strong key: php spark key:generate
# encryption.key = 

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# Use database session for production (recommended)
session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.savePath = 'sessions'

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
# Log level: 1=error, 2=warning, 3=notice, 4=info, 5=debug
logger.threshold = 2

#--------------------------------------------------------------------
# OTHER SETTINGS
#--------------------------------------------------------------------
# Uncomment these for production security
# app.forceGlobalSecureRequests = true
# security.tokenRandomize = true
# security.csrfProtection = 'session'
# security.csrfTokenRandomize = true
